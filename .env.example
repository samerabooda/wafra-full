APP_NAME="Wafra Gulf Commission Cards"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=Asia/Kuwait
APP_URL=https://systemv1.wafragulf.com
APP_LOCALE=ar
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=daily
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=wafra_gulf
DB_USERNAME=root
DB_PASSWORD=

# ── Session ────────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=480
SESSION_ENCRYPT=false
SESSION_DOMAIN=.wafragulf.com
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax
SESSION_HTTP_ONLY=true

# ── Sanctum ────────────────────────────────────────────────────
SANCTUM_STATEFUL_DOMAINS=systemv1.wafragulf.com,wafragulf.com

# ── CORS ───────────────────────────────────────────────────────
FRONTEND_URL=https://systemv1.wafragulf.com

# ── Cache / Queue ──────────────────────────────────────────────
CACHE_STORE=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=local

# ── Mail (optional) ────────────────────────────────────────────
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@wafragulf.com"
MAIL_FROM_NAME="${APP_NAME}"
